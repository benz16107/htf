DATABASE_URL="postgresql://postgres:postgres@localhost:5432/htf?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/htf?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required for session cookie signing (auth). Generate with: openssl rand -hex 32
SESSION_SECRET="replace-me-with-at-least-16-chars"

# LLM and memory services
GEMINI_API_KEY="replace-me"
# Optional global default model (overridden per-company in Integrations UI)
GEMINI_MODEL="gemini-2.5-flash"
BACKBOARD_API_KEY="replace-me"

# Zapier MCP embed (mcp.zapier.com): embed ID is public; secret is server-only.
NEXT_PUBLIC_ZAPIER_MCP_EMBED_ID="replace-me"
ZAPIER_MCP_EMBED_SECRET="replace-me"

# Recommended for internal autonomous/live-ingest route authorization.
INTERNAL_API_SECRET="replace-me"

GOOGLE_CLIENT_ID="replace-me.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="replace-me"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/email/google/callback"
GOOGLE_PUBSUB_TOPIC_NAME="projects/your-project/topics/your-topic"
GOOGLE_PUBSUB_VERIFICATION_TOKEN="replace-me"
