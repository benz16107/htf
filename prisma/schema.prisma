generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum CompanyRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum AgentType {
  AI_SETUP
  SIGNAL_RISK
}

enum AccessScope {
  SELF_ONLY
  COMPANY_ALL
}

enum SessionStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum RiskSeverity {
  MINOR
  MODERATE
  SEVERE
  CRITICAL
}

enum ScenarioRecommendation {
  RECOMMENDED
  FALLBACK
  ALTERNATE
}

model User {
  id             String            @id @default(cuid())
  externalAuthId String?           @unique
  email          String            @unique
  passwordHash   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  companies      UserCompanyRole[]
}

model Company {
  id               String                 @id @default(cuid())
  key              String                 @unique
  name             String
  setupCompleted   Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  users            UserCompanyRole[]
  baseProfile      CompanyProfileBase?
  highLevelProfile CompanyProfileHighLevel?
  integrations     IntegrationConnection[]
  overridePolicies OverridePolicy[]
  memoryThreads    MemoryThread[]
  agentSessions    AgentSession[]
  riskCases              RiskCase[]
  playbookEntries        PlaybookEntry[]
  ingestedEvents         IngestedEvent[]
  savedExternalSignals   SavedExternalSignal[]
  autonomousAgentConfig AutonomousAgentConfig?
  autonomousAgentLogs    AutonomousAgentLog[]
  assessmentArchives    AssessmentArchive[]
  chatThreads           ChatThread[]
  chatMessages          ChatMessage[]
}

model UserCompanyRole {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model CompanyProfileBase {
  id                String   @id @default(cuid())
  companyId         String   @unique
  sector            String?
  companyType       String?
  sizeBand          String?
  industryStance    String?
  supplyChainMap    Json?
  stakeholderMap    Json?
  assumptions       Json?
  rawInput          String?
  generatedSummary  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyProfileHighLevel {
  id                        String   @id @default(cuid())
  companyId                 String   @unique
  existingRiskAnalysis      Json?
  leadTimeSensitivity       Json?
  inventoryBufferPolicies   Json?
  contractStructures        Json?
  customerSlaProfile        Json?
  erpSignalMonitoring       Json?
  generatedNarrative        String?
  warningSummary            String?
  confidenceScore           String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model IntegrationConnection {
  id              String   @id @default(cuid())
  companyId       String
  provider        String
  status          String
  authType        String
  metadata        Json?
  connectedAt     DateTime @default(now())
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([companyId, provider])
}

model MemoryThread {
  id                String      @id @default(cuid())
  companyId         String
  agentType         AgentType
  accessScope       AccessScope
  backboardAssistantId String
  backboardThreadId String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, agentType])
}

model AgentSession {
  id             String          @id @default(cuid())
  companyId      String
  agentType      AgentType
  status         SessionStatus
  startedAt      DateTime        @default(now())
  endedAt        DateTime?
  metadata       Json?
  traces         ReasoningTrace[]
  riskCases      RiskCase[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, agentType, startedAt])
}

model ReasoningTrace {
  id            String       @id @default(cuid())
  companyId     String
  sessionId     String
  stepKey       String
  stepTitle     String
  rationale     String
  evidencePack  Json?
  assumptions   Json?
  confidence    String?
  createdAt     DateTime     @default(now())
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([companyId, sessionId, createdAt])
}

model RiskCase {
  id                       String        @id @default(cuid())
  companyId                String
  sessionId                String
  triggerType              String
  createdByAutonomousAgent Boolean       @default(false)
  entityMap             Json
  timeWindow            Json
  evidencePack          Json
  assumptions           Json
  constraints           Json
  probabilityPoint      Float?
  probabilityBandLow    Float?
  probabilityBandHigh   Float?
  confidenceLevel       String?
  /** Key drivers from the risk assessment (e.g. probability.topDrivers) */
  keyDrivers            Json?
  severity              RiskSeverity?
  serviceImpact         Json?
  financialImpact       Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  company               Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session               AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scenarios             Scenario[]
  mitigationPlans       MitigationPlan[]

  @@index([companyId, createdAt])
}

model Scenario {
  id                 String                  @id @default(cuid())
  riskCaseId         String
  name               String
  recommendation     ScenarioRecommendation
  costDelta          Float?
  serviceImpact      Float?
  riskReduction      Float?
  timeToImplementHrs Int?
  confidenceLevel    String?
  assumptions        Json?
  /** Short list of subjects/tasks this scenario will draft (e.g. ["Notify primary supplier", "Expedite shipping"]) */
  planOutline        Json?
  createdAt          DateTime                @default(now())
  riskCase           RiskCase                @relation(fields: [riskCaseId], references: [id], onDelete: Cascade)

  @@index([riskCaseId, recommendation])
}

model MitigationPlan {
  id                       String   @id @default(cuid())
  companyId                String
  riskCaseId               String
  scenarioId               String?
  owner                    String?
  status                   String
  actions                  Json
  executionMode            String
  createdByAutonomousAgent Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  riskCase                 RiskCase @relation(fields: [riskCaseId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

/// Archived risk assessments (sent to mitigation) from manual flow or autonomous agent. Shown on Signals page.
model AssessmentArchive {
  id           String   @id @default(cuid())
  companyId    String
  triggerType  String
  issueTitle   String?
  entityMap    Json
  timeWindow   Json
  assumptions  Json
  assessment   Json
  sentAt       DateTime @default(now())
  source       String   @default("manual") // "manual" | "autonomous"
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model OverridePolicy {
  id                    String   @id @default(cuid())
  companyId             String
  name                  String
  revenueAtRiskLimit    Float?
  otifFloor             Float?
  probabilityThreshold  Float?
  autoExecuteEnabled    Boolean  @default(false)
  rules                 Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model PlaybookEntry {
  id                String   @id @default(cuid())
  companyId         String
  incidentClass     String
  predictedOutcome  Json
  actualOutcome     Json
  effectiveness     Json
  learnings         Json
  createdAt         DateTime @default(now())
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, incidentClass])
}

model IngestedEvent {
  id                     String    @id @default(cuid())
  companyId              String
  source                 String
  toolName               String
  externalId             String?   // e.g. Gmail message_id — used to avoid duplicates when scanning again
  rawContent             Json?
  signalSummary          String?
  createdAt              DateTime  @default(now())
  /** Set when the autonomous agent has processed this event (assess + optional draft/execute). */
  autonomousProcessedAt  DateTime?
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, toolName, externalId])
  @@index([companyId, autonomousProcessedAt])
}

model SavedExternalSignal {
  id                     String    @id @default(cuid())
  companyId              String
  title                  String
  snippet                String
  url                    String?
  source                 String?
  articlePublishedAt     DateTime?
  createdAt              DateTime  @default(now())
  /** Set when the autonomous agent has processed this signal. */
  autonomousProcessedAt  DateTime?
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

/// One per company. Controls how the autonomous agent reacts to signals (assess, draft, execute).
model AutonomousAgentConfig {
  id                          String   @id @default(cuid())
  companyId                   String   @unique
  /** When true, the agent runs continuously until toggled off. */
  agentRunning                Boolean  @default(false)
  /** Off | assess only | draft only (no auto-execute) | full auto (draft + execute when allowed). */
  automationLevel             String   @default("off")
  /** Which signals to process: internal_only | external_only | both. */
  signalSources               String   @default("both")
  /** When to pick up internal signals: lookback (poll within window) | live (trigger as soon as received). */
  internalSignalMode          String   @default("lookback")
  /** How far back (minutes) to look for unprocessed internal signals (used when internalSignalMode is lookback). */
  internalSignalLookbackMinutes Int     @default(10)
  /** How far back (minutes) to look for unprocessed external signals. */
  externalSignalLookbackMinutes Int     @default(10)
  /** Minimum severity to act on: MINOR, MODERATE, SEVERE, CRITICAL. */
  minSeverityToAct            String   @default("MODERATE")
  /** Min probability (0–100) to create case and draft. */
  minProbabilityToAct         Float    @default(0)
  /** Min revenue at risk (USD) to act; null = no floor. */
  minRevenueAtRiskToAct       Float?
  /** Require human approval when severity is at or above this (e.g. CRITICAL). */
  requireApprovalForSeverity  String?
  /** Require human approval when revenue at risk (USD) is above this; null = no cap. */
  requireApprovalForRevenueAbove  Float?
  /** Require human approval when probability is above this (0–100); null = no cap. */
  requireApprovalForProbabilityAbove Float?
  /** Max number of plans to auto-execute per day (0 = no auto-execute). */
  maxAutoExecutionsPerDay     Int      @default(5)
  /** Action types allowed for auto-execute (e.g. ["zapier_mcp","email"]); empty = none. */
  allowedActionTypesToAutoExecute Json?
  /** Require approval for first N incidents per day (e.g. first 1 always needs approval). */
  requireApprovalForFirstNPerDay   Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  company                    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

/// One row per action taken by the autonomous agent (assess, create case, draft plan, execute).
model AutonomousAgentLog {
  id          String   @id @default(cuid())
  companyId   String
  /** Groups all entries from a single "Run now" / cron invocation. */
  runId       String
  /** run_started | signal_assessed | signal_skipped | risk_case_created | plan_drafted | plan_executed | run_completed */
  actionType  String
  /** internal | external (for signal-related actions). */
  signalType  String?
  signalId    String?
  riskCaseId  String?
  planId      String?
  /** Short human-readable summary (e.g. trigger title, reason skipped). */
  summary     String?
  /** Extra context: severity, probability, revenue at risk, etc. */
  details     Json?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, runId])
}

/// User-facing business chat threads (Q&A only in v1).
model ChatThread {
  id          String        @id @default(cuid())
  companyId   String
  title       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([companyId, updatedAt])
}

/// Individual chat turns for business assistant conversations.
model ChatMessage {
  id          String      @id @default(cuid())
  threadId    String
  companyId   String
  role        String
  content     String
  citations   Json?
  confidence  String?
  createdAt   DateTime    @default(now())
  thread      ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([companyId, createdAt])
}
